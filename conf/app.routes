GET   /messages                                     controllers.SecureMessageFrontendController.list(taxIdentifiers: List[String], regimes: List[String])
GET   /messages/bta                                 controllers.SecureMessageFrontendController.btaList(taxIdentifiers: List[String], regimes: List[String])

GET   /messages/count                               controllers.SecureMessageFrontendController.count(read: Option[model.ReadPreference.Value], taxIdentifiers: List[String], regimes: List[String])

GET   /messages/inbox-link                          controllers.SecureMessageFrontendController.inboxLink(messagesInboxUrl: RedirectUrl, taxIdentifiers: List[String], regimes: List[String])
GET   /messages/:encryptedUrl                       controllers.SecureMessageFrontendController.read(encryptedUrl: binders.Encrypted[binders.ParameterisedUrl])